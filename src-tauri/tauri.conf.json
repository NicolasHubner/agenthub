{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentHub",
  "version": "0.1.0",
  "identifier": "com.agenthub.desktop",
  "build": {
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": {
      "resources/agenthub": "agenthub",
      "../ui/dist/*": "ui-dist/",
      "../ui/dist/assets/*": "ui-dist/assets/"
    }
  }
}
